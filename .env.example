# ── Ngrok ──────────────────────────────────────
NGROK_TOKEN=your_ngrok_token_here

# ── Anthropic (Claude LLM Judge) ───────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Backend URL (Node.js backend) ──────────────
BACKEND_URL=http://localhost:3000

# ── Flask ──────────────────────────────────────
FLASK_PORT=5000

# ── GPU / Clustering ───────────────────────────
GPU_EVAL_SLOTS=3
NUM_CLUSTERS=7
DBSCAN_EPS=0.05
DBSCAN_MIN_SAMPLES=3

# ── Storage paths ──────────────────────────────
UPLOAD_FOLDER=./dataset_uploads
LOCAL_CHECKPOINT_BASE=/tmp/checkpoints
